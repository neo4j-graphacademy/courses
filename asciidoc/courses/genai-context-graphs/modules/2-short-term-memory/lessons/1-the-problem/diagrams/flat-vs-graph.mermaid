%%{init: {'theme': 'base', 'themeVariables': { 
  'primaryColor': '#014063', 
  'primaryTextColor': '#fff', 
  'primaryBorderColor': '#014063', 
  'lineColor': '#A5ABB6', 
  'secondaryColor': '#006E58', 
  'tertiaryColor': '#F5F7FA',
  'background': '#F5F7FA',
  'mainBkg': '#57C7E3',
  'secondBkg': '#F79767',
  'edgeLabelBackground': '#FFFFFF',
  'clusterBkg': '#F5F7FA',
  'clusterBorder': '#485662'
}}}%%
graph TB
    subgraph query["Query: 'Which messages mentioned Jessica Norris?'"]
        Q[AI Agent Processing Query]
    end
    
    subgraph flat["❌ Flat Text Log - Returns Too Much Data"]
        Q --> L[Flat Log]
        L --> L1["[10:23] System: Connection established ❌"]
        L --> L2["[10:24] User: Review Jessica Norris account ✓"]
        L --> L3["[10:24] Agent: Processing request... ❌"]
        L --> L4["[10:25] System: Database query executed ❌"]
        L --> L5["[10:25] Agent: Retrieved account details ❌"]
        L --> L6["[10:26] User: What was last transaction? ❌"]
        L --> L7["[10:27] Agent: Requesting clarification ❌"]
        L --> L8["[10:28] User: For Jessica Norris account ✓"]
        L --> L9["[10:29] System: Processing query... ❌"]
        L --> L10["[10:30] Agent: Transaction history... ❌"]
        L -.-> R1["Returns: 10 log entries<br/>Only 2 relevant 20%<br/>8 irrelevant 80%"]
        
        style L1 fill:#FFE5E5
        style L2 fill:#E7FAFB
        style L3 fill:#FFE5E5
        style L4 fill:#FFE5E5
        style L5 fill:#FFE5E5
        style L6 fill:#FFE5E5
        style L7 fill:#FFE5E5
        style L8 fill:#E7FAFB
        style L9 fill:#FFE5E5
        style L10 fill:#FFE5E5
        style R1 fill:#FFE5E5,stroke:#CC0000
    end
    
    subgraph graph["✓ Knowledge Graph - Returns Only Relevant Data"]
        Q --> G[Knowledge Graph]
        G --> M1[Message 1:<br/>Review account]
        G --> M2[Message 2:<br/>Last transaction?]
        G --> M3[Message 3:<br/>For J. Norris]
        M1 -.MENTIONS.-> E[Jessica Norris]
        M2 -.MENTIONS.-> E
        M3 -.MENTIONS.-> E
        G -.-> R2["Returns: 3 messages<br/>All relevant 100%<br/>Direct traversal via<br/>MENTIONS relationships"]
        
        style M1 fill:#57C7E3,stroke:#014063
        style M2 fill:#57C7E3,stroke:#014063
        style M3 fill:#57C7E3,stroke:#014063
        style E fill:#F79767,stroke:#014063
        style R2 fill:#E7FAFB,stroke:#00CC52
    end
    
    style query fill:#F5F7FA,stroke:#014063
    style Q fill:#014063,color:#FFFFFF
    style flat fill:#FFE5E5,stroke:#CC0000
    style graph fill:#E7FAFB,stroke:#00CC52
    style L fill:#F5F7FA,stroke:#485662
    style G fill:#F5F7FA,stroke:#006E58
