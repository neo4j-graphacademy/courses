{
  "name": "Neo4j Context Providers for Microsoft Agent Framework",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
  "postCreateCommand": "bash .devcontainer/post_create.sh",
  "customizations": {
    "codespaces": {
      "openFiles": [
        ".devcontainer/SETUP.md",
        ".env.example",
        "genai-maf-context-providers/test_environment.py"
      ]
    },
    "vscode": {
      "settings": {
        "python.createEnvironment.trigger": "off",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-toolsai.jupyter",
        "neo4j-extensions.neo4j-for-vscode"
      ]
    }
  },
  "secrets": {
    "OPENAI_API_KEY": {
      "description": "OpenAI API key for LLM access (from platform.openai.com or provided by instructor)"
    },
    "NEO4J_URI": {
      "description": "Neo4j Sandbox Bolt URI (e.g. neo4j+s://xxxxx.databases.neo4j.io)"
    },
    "NEO4J_USERNAME": {
      "description": "Neo4j username (default: neo4j)"
    },
    "NEO4J_PASSWORD": {
      "description": "Neo4j Sandbox password"
    }
  }
}
