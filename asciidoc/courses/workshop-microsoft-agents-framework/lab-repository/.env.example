# LLM Provider: "openai" (default) or "azure"
LLM_PROVIDER="openai"

# === OpenAI Direct ===
OPENAI_API_KEY="sk-"
OPENAI_RESPONSES_MODEL_ID="gpt-5-mini"

# === Azure AI Foundry (set LLM_PROVIDER="azure" to use) ===
# AZURE_OPENAI_API_KEY=""
# AZURE_OPENAI_ENDPOINT="https://ai-xxxxx.cognitiveservices.azure.com/"
# AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME="gpt-5-mini"
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME="text-embedding-3-small"
# AZURE_OPENAI_API_VERSION="2025-03-01-preview"

# === Neo4j ===
NEO4J_URI="neo4j+s://"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD=""
NEO4J_VECTOR_INDEX_NAME="moviePlots"
NEO4J_FULLTEXT_INDEX_NAME="moviePlotsFulltext"
